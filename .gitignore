# Ignore local data and outputs, keep code tracked

# Data directories (do not track large datasets)
Projet/donnees/
donnees/

# Output / generated files
output/
**/output/
*.xlsx

# Python cache and build artifacts
__pycache__/
*.py[cod]
*$py.class
*.pyc
dist/
build/
*.egg-info/

# Virtual environments
.venv/
venv/
ENV/

# IDE/editor
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Binary extensions
*.so
*.pyd
*.dll

# Keep repository essentials
!.gitignore
!README.md
!requirements.txt

